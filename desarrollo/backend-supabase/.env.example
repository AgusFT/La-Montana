# Supabase - entorno de desarrollo
SUPABASE_PROJECT_REF=acmytbjkopdbbwlnovoe
SUPABASE_URL=https://acmytbjkopdbbwlnovoe.supabase.co

# Completar localmente en .env, nunca commitear claves reales.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Cifrado cliente de archivos (#113 / #117).
# Publica la clave publica con la Edge Function clave-publica-cifrado.
# La clave privada correspondiente debe quedar solo como secret backend y nunca
# exponerse al frontend ni commitearse.
CLAVE_PUBLICA_CIFRADO_ARCHIVOS=
VERSION_CIFRADO_ARCHIVOS=aes-256-gcm+rsa-oaep-sha256:v1
