@startuml der_modelo_datos_supabase

' DER del modelo de datos Supabase/PostgreSQL para el MVP de La Montana.
' Fuente documental: guia-estilo-bdd.md y modelo-tablas-relaciones-supabase.md.
' Issue relacionada: #121.

title DER modelo de datos Supabase - MVP La Montana

left to right direction
hide circle

skinparam linetype ortho
skinparam shadowing false
skinparam roundcorner 8
skinparam nodesep 110
skinparam ranksep 130
skinparam padding 6
skinparam entity {
  BackgroundColor #FFFFFF
  BorderColor #2F3A45
  FontColor #111827
}

entity "auth.users" as auth_users {
  * id : uuid [PK]
  --
  email : text
}

entity "rol" as rol {
  * id_rol : bigint [PK]
  --
  codigo : text
  nombre : text
  descripcion : text
  activo : boolean
}

entity "permiso" as permiso {
  * id_permiso : bigint [PK]
  --
  codigo : text
  nombre : text
  descripcion : text
  activo : boolean
}

entity "rol_permiso" as rol_permiso {
  * id_rol_permiso : bigint [PK]
  --
  id_rol : bigint [FK rol.id_rol]
  id_permiso : bigint [FK permiso.id_permiso]
}

entity "contacto" as contacto {
  * id_contacto : bigint [PK]
  --
  id_usuario : bigint [FK usuario.id_usuario]
  tipo_contacto : text/enum
  valor : text
  principal : boolean
  verificado : boolean
}

entity "usuario" as usuario {
  * id_usuario : bigint [PK]
  --
  id_usuario_auth : uuid [FK auth.users.id]
  id_rol : bigint [FK rol.id_rol]
  nombre : text
  apellido : text
  email : text
  estado : text/enum
  observacion : text
}

entity "pedido" as pedido {
  * id_pedido : bigint [PK]
  --
  id_usuario : bigint [FK usuario.id_usuario]
  id_punto_entrega : bigint [FK punto_entrega.id_punto_entrega]
  codigo : text
  descripcion : text
  observacion_cliente : text
  observacion_interna : text
  cantidad_estimada : integer
  cantidad_carillas : integer
  estado_interno : text/enum
  estado_visible_cliente : text/enum
  estado_financiero : text/enum
  requiere_senia : boolean
  porcentaje_senia : numeric
  total_estimado : numeric
}

entity "pedido_servicio" as pedido_servicio {
  * id_pedido_servicio : bigint [PK]
  --
  id_pedido : bigint [FK pedido.id_pedido]
  id_servicio : bigint [FK servicio.id_servicio]
  cantidad : numeric
  precio_unitario_aplicado : numeric
  subtotal : numeric
  observacion : text
}

entity "direccion" as direccion {
  * id_direccion : bigint [PK]
  --
  id_usuario : bigint [FK usuario.id_usuario]
  calle : text
  numero : text
  piso : text
  departamento : text
  localidad : text
  provincia : text
  codigo_postal : text
  referencia : text
  principal : boolean
}

entity "punto_entrega" as punto_entrega {
  * id_punto_entrega : bigint [PK]
  --
  nombre : text
  descripcion : text
  direccion_texto : text
  horario_atencion : text
  activo : boolean
}

entity "servicio" as servicio {
  * id_servicio : bigint [PK]
  --
  codigo : text
  nombre : text
  descripcion : text
  precio_base : numeric
  tipo_moneda : text/enum
  activo : boolean
}

entity "archivo" as archivo {
  * id_archivo : bigint [PK]
  --
  id_pedido : bigint [FK pedido.id_pedido]
  id_usuario : bigint [FK usuario.id_usuario]
  nombre_original : text
  mime_original : text
  tamano_bytes : bigint
  hash_archivo : text
  bucket : text
  ruta_storage : text
  clave_envuelta : text
  iv : text
  version_cifrado : text
  estado_archivo : text/enum
}

entity "auditoria" as auditoria {
  * id_auditoria : bigint [PK]
  --
  id_usuario_actor : bigint [FK usuario.id_usuario]
  id_pedido : bigint [FK pedido.id_pedido]
  tabla_afectada : text
  id_registro_afectado : text
  accion : text
  nivel : text/enum
  codigo : text
  mensaje : text
  request_id : uuid/text
  metadata : jsonb
  fecha_creacion : timestamptz
}

entity "pago_pedido" as pago_pedido {
  * id_pago_pedido : bigint [PK]
  --
  id_pago : bigint [FK pago.id_pago]
  id_pedido : bigint [FK pedido.id_pedido]
  monto_aplicado : numeric
  tipo_aplicacion : text/enum
  observacion : text
}

entity "pago" as pago {
  * id_pago : bigint [PK]
  --
  id_usuario_registro : bigint [FK usuario.id_usuario]
  monto : numeric
  tipo_moneda : text/enum
  medio_pago : text/enum
  estado : text/enum
  fecha_pago : timestamptz
  referencia : text
  observacion : text
}

' Guias invisibles de layout para formar una estructura radial y simetrica.
auth_users -[hidden]right- rol
rol -[hidden]right- permiso
permiso -[hidden]right- rol_permiso
rol_permiso -[hidden]right- punto_entrega
punto_entrega -[hidden]right- servicio

contacto -[hidden]right- usuario
usuario -[hidden]right- pedido
pedido -[hidden]right- pedido_servicio
pedido_servicio -[hidden]right- archivo

direccion -[hidden]right- auditoria
auditoria -[hidden]right- pago_pedido
pago_pedido -[hidden]right- pago

auth_users -[hidden]down- contacto
rol -[hidden]down- usuario
permiso -[hidden]down- pedido
rol_permiso -[hidden]down- pedido_servicio
punto_entrega -[hidden]down- pedido
servicio -[hidden]down- pedido_servicio

contacto -[hidden]down- direccion
usuario -[hidden]down- auditoria
pedido -[hidden]down- pago_pedido
pedido_servicio -[hidden]down- pago

' Relaciones de identidad, autorizacion y ownership.
auth_users ||------o| usuario : "1 a 0..1"
rol ||------o{ usuario : "1 a N"
rol ||------o{ rol_permiso : "1 a N"
permiso ||------o{ rol_permiso : "1 a N"

' Relaciones directas del usuario.
usuario ||------o{ contacto : "1 a N"
usuario ||------o{ direccion : "1 a N"
usuario ||------o{ pedido : "1 a N"
usuario ||------o{ archivo : "1 a N"
usuario ||------o{ pago : "1 a N"
usuario ||------o{ auditoria : "1 a N"

' Relaciones operativas del pedido.
punto_entrega ||------o{ pedido : "1 a N"
pedido ||------o{ pedido_servicio : "1 a N"
servicio ||------o{ pedido_servicio : "1 a N"
pedido ||------o{ archivo : "1 a N"
pedido ||------o{ pago_pedido : "1 a N"
pago ||------o{ pago_pedido : "1 a N"
pedido ||------o{ auditoria : "1 a N"

@enduml
